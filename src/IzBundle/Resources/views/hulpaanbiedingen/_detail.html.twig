<h2>Hulpaanbod</h2>
<p>
    {% if not entity.afgesloten %}
        {{ html.editLink(path(route_base~'edit', {id: entity.id})) }}
        {{ html.link('Bewerken', path(route_base~'edit', {id: entity.id})) }}
        {% if not entity.gekoppeld %}
            {{ html.closeLink(path(route_base~'close', {id: entity.id})) }}
            {{ html.link('Afsluiten', path(route_base~'close', {id: entity.id})) }}
        {% endif %}
    {% endif %}
</p>
<dl class="dl-horizontal">
    <dt>Vrijwilliger</dt>
    <dd>{{ html.link(entity.izVrijwilliger, path('iz_vrijwilligers_view', {id: entity.izVrijwilliger.id})) }}</dd>
    <dt>Medewerker</dt>
    <dd>{{ entity.medewerker }}</dd>
    <dt>Startdatum</dt>
    <dd>{{ entity.startdatum|date('d-m-Y') }}</dd>
    {% if entity.afgesloten %}
        <dt>Afsluitdatum</dt>
        <dd>{{ entity.einddatum ? entity.einddatum|date('d-m-Y') }}</dd>
        <dt>Afsluitreden</dt>
        <dd>{{ entity.eindeVraagAanbod }}</dd>
    {% endif %}
</dl>
<dl class="dl-horizontal">
    <dt>Project</dt>
    <dd>{{ entity.project }}</dd>
    <dt>Hulpvraagsoorten</dt>
    <dd>
        <ul>
            {% for hulpvraagsoort in entity.hulpvraagsoorten %}
                <li>{{ hulpvraagsoort }}</li>
            {% endfor %}
        </ul>
    </dd>
    <dt>Beschikbare dagen</dt>
    <dd>
        <ul>
            {% for dag in entity.beschikbareDagen %}
                <li>{{ dag }}</li>
            {% endfor %}
        </ul>
    </dd>
    <dt>Voorkeur stadsdelen</dt>
    <dd>
        <ul>
            {% for stadsdeel in entity.voorkeurStadsdelen %}
                <li>{{ stadsdeel }}</li>
            {% endfor %}
        </ul>
    </dd>
    <dt>Voorkeur geslacht</dt>
    <dd>{{ entity.voorkeurGeslacht ?: 'Geen voorkeur' }}</dd>
    <dt>Voorkeur leeftijd</dt>
    <dd>
        <ul>
            <li>Minimaal: {{ entity.voorkeurMinLeeftijd ? entity.voorkeurMinLeeftijd~' jaar' : 'geen voorkeur' }}</li>
            <li>Maximaal: {{ entity.voorkeurMaxLeeftijd ? entity.voorkeurMaxLeeftijd~' jaar' : 'geen voorkeur' }}</li>
        </ul>
    </dd>
    <dt>Voorkeur roken</dt>
    <dd>{{ entity.voorkeurNietRoker ? 'Voorkeur voor niet-roker' : 'Geen voorkeur' }}</dd>
    <dt>Voorkeur huisdieren</dt>
    <dd>{{ entity.voorkeurGeenDieren ? 'Voorkeur voor geen huisdieren' : 'Geen voorkeur' }}</dd>
    <dt>Matchingsinformatie</dt>
    <dd><div class="well">{{ entity.info }}</div></dd>
</dl>
