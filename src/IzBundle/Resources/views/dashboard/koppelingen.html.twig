{% extends '::base.html.twig' %}
{% import '::html.macro.twig' as html %}
{% import 'IzBundle::iz.macro.twig' as iz %}

{% block title %}
    Informele Zorg | {{ title }}
{% endblock %}

{% block subnavigation %}
    {% include '@Iz/subnavigation.html.twig' %}
{% endblock %}

{% block content %}
    <span class="pull-right">
        {{ form(medewerker_filter) }}
    </span>
    <h1>{{ title }}</h1>
    <ul class="nav nav-tabs">
        <li class="active"><a href="{{ path('iz_dashboard_koppelingen', {medewerker: medewerker_filter.vars.value}) }}">Lopende koppelingen</a></li>
        <li><a href="{{ path('iz_dashboard_hulpvragen', {medewerker: medewerker_filter.vars.value}) }}">Open hulpvragen</a></li>
        <li><a href="{{ path('iz_dashboard_hulpaanbiedingen', {medewerker: medewerker_filter.vars.value}) }}">Open hulpaanbiedingen</a></li>
    </ul>
    <div class="tab-content">
        <div id="hulpvragen" class="tab-pane">
        </div>
        <div id="hulpaanbiedingen" class="tab-pane">
        </div>
        <div id="koppelingen" class="tab-pane active">
            <h2>Lopende koppelingen</h2>
            <table class="table table-hover">
                <thead>
                    <tr>
                        {{ form_start(filter) }}
                            <tr>
                                <th colspan="8">
                                    <span class="pull-right">
                                        {{ form_widget(filter.filter) }}
                                        {{ form_widget(filter.download) }}
                                    </span>
                                </th>
                            </tr>
                            <tr>
                                <th>
                                    {{ form_widget(filter.status) }}
                                    {{ form_errors(filter.status) }}
                                </th>
                                <th>
                                    {{ form_widget(filter.izKlant.datumAanmelding.start) }}
                                    {{ form_errors(filter.izKlant.datumAanmelding.start) }}
                                    {{ form_widget(filter.izKlant.datumAanmelding.end) }}
                                    {{ form_errors(filter.izKlant.datumAanmelding.end) }}
                                </th>
                                <th>
                                    {{ form_widget(filter.klant.voornaam) }}
                                    {{ form_errors(filter.klant.voornaam) }}
                                    {{ form_widget(filter.klant.achternaam) }}
                                    {{ form_errors(filter.klant.achternaam) }}
                                </th>
                                <th>
                                    {{ form_widget(filter.vrijwilliger.voornaam) }}
                                    {{ form_errors(filter.vrijwilliger.voornaam) }}
                                    {{ form_widget(filter.vrijwilliger.achternaam) }}
                                    {{ form_errors(filter.vrijwilliger.achternaam) }}
                                </th>
                                <th>
                                    {{ form_widget(filter.startdatum) }}
                                    {{ form_errors(filter.startdatum) }}
                                </th>
                                <th>
                                   {{ form_widget(filter.hulpvraag.hulpvraagsoort) }}
                                   {{ form_errors(filter.hulpvraag.hulpvraagsoort) }}
                                </th>
                                <th>
                                    {{ form_widget(filter.klant.stadsdeel) }}
                                    {{ form_errors(filter.klant.stadsdeel) }}
                                </th>
                                <th>
                                </th>
                            </tr>
                        {{ form_end(filter) }}
                    </tr>
                    <tr>
                        <th>
                            {{ knp_pagination_sortable(pagination, 'Status', 'status.naam') }}
                        </th>
                        <th>
                            {{ knp_pagination_sortable(pagination, 'Aanmelddatum deelnemer', 'izKlant.datumAanmelding') }}
                        </th>
                        <th>
                            {{ knp_pagination_sortable(pagination, 'Deelnemer', 'klant.achternaam') }}
                        </th>
                        <th>
                            {{ knp_pagination_sortable(pagination, 'Vrijwilliger', 'vrijwilliger.achternaam') }}
                        </th>
                        <th>
                            {{ knp_pagination_sortable(pagination, 'Startdatum koppeling', 'koppeling.startdatum') }}
                        </th>
                        <th>
                            {{ knp_pagination_sortable(pagination, 'Hulpvraagsoort', 'hulpvraagsoort.naam') }}
                        </th>
                        <th>
                            {{ knp_pagination_sortable(pagination, 'Werkgebied', 'werkgebied.naam') }}
                        </th>
                        <th>
                            Evaluaties
                        </th>
                    </tr>
                </thead>
                <tbody>
                    {% for koppeling in pagination %}
                        <tr data-href="{{ path('iz_koppelingen_view', {id: koppeling.id}) }}">
                            <td>
                                {{ koppeling.status }}
                            </td>
                            <td>
                                {{ koppeling.hulpvraag.izKlant.datumAanmelding|date('d-m-Y') }}
                            </td>
                            <td>
                                {{ koppeling.hulpvraag.izKlant }}
                            </td>
                            <td>
                                {{ koppeling.hulpaanbod.izVrijwilliger }}
                            </td>
                            <td>
                                {{ koppeling.startdatum|date('d-m-Y') }}
                            </td>
                            <td>
                                {{ koppeling.hulpvraag.hulpvraagsoort }}
                            </td>
                            <td>
                                {{ koppeling.hulpvraag.izKlant.klant.werkgebied }}
                            </td>
                            <td>
                                {{ iz.koppeling_evaluatie_list(koppeling) }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            {{ knp_pagination_render(pagination) }}
        </div>
    </div>
{% endblock %}

{% block scripts %}
    <script type="text/javascript">
        $(function() {
            $('form #medewerker_select').change(function() {
                $(this).closest('form').submit();
            });
        });
    </script>
{% endblock %}
